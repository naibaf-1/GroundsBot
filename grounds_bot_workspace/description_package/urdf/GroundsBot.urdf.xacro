<?xml version="1.0"?>
<robot name="GroundsBot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Xacro properties -->
  <xacro:property name="width" value="3.2"/>
  <xacro:property name="height" value="1.5"/>
  <xacro:property name="length" value="3.6"/>

  <!-- Colors -->
  <material name="grey">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.1 0.1 1.0"/>
  </material>
  
  <!-- Xacro macros -->
  <xacro:macro name="wheel" params="prefix">
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="0.7" length="0.6"/>
        </geometry>
        <material name="black"/>
      </visual>
    </link>
  </xacro:macro>

  <!-- Links -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.75" rpy="0 0 0"/>
      <geometry>
        <box size="3.0 ${width - 1.2} ${height}"/>
      </geometry>
      <material name="grey"/>
    </visual>
  </link>
  <link name="cutting_unit_link">
    <visual>
      <origin xyz="0.8 0 0.25" rpy="0 0 0"/>
      <geometry>
        <box size="1.6 ${width} ${height / 3}"/>
      </geometry>
      <material name="grey"/>
    </visual>
  </link>
  <xacro:wheel prefix="front_left"/>
  <xacro:wheel prefix="front_right"/>
  
  <!-- Joints -->
  <joint name="base_cutting_unit_joint" type="fixed">
    <parent link="base_link"/>
    <child link="cutting_unit_link"/>
    <origin xyz="1.5 0 0" rpy="0 0 0"/>
  </joint>
  <joint name="base_front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel_link"/>
    <origin xyz="0.75 -1.3 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
  <joint name="base_front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel_link"/>
    <origin xyz="0.75 1.3 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

</robot>

