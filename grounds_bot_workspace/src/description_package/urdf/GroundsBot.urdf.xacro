<?xml version="1.0"?>
<robot name="GroundsBot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Include other xacro files -->
<xacro:include filename="$(find description_package)/urdf/inertia_properties.xacro" />  

  <!-- Xacro properties -->
  <xacro:property name="width" value="3.0"/>
  <xacro:property name="height" value="1.5"/>
  <xacro:property name="length" value="4.5"/>
  <xacro:property name="wheel_radius" value="0.7"/>
  <xacro:property name="wheel_width" value="0.6"/>

  <!-- Colors -->
  <material name="grey">
    <color rgba="0.7 0.7 0.7 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.1 0.1 1.0"/>
  </material>
  
  <!-- Xacro macros -->
  <xacro:macro name="wheel" params="prefix">
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <origin xyz="" rpy=""/>
      </collision>
      <xacro:cylinder_inertia m="0.25" r="${wheel_radius}" l="${wheel_width}"
                              o_xyz="0 0 0" o_rpy="0 0 0"/>
    </link>
  </xacro:macro>

  <!-- Links -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${height / 2}" rpy="0 0 0"/>
      <geometry>
        <box size="${(length / 3) * 2} ${width - (wheel_width * 2)} ${height}"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="${(length / 3) * 2} ${width - (wheel_width * 2)} ${height}"/>
      </geometry>
      <origin xyz="" rpy=""/>
    </collision>
    <xacro:box_inertia m="3.0" x="${(length / 3) * 2}" y="${width - (wheel_width * 2)}" z="${height}"
                       o_xyz="0 0 ${height / 2}" o_rpy="0 0 0"/>
  </link>
  <link name="cutting_unit_link">
    <visual>
      <origin xyz="${length / 6} 0 ${height / 6}" rpy="0 0 0"/>
      <geometry>
        <box size="${length / 3} ${width} ${height / 3}"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
          <box size="${length / 3} ${width} ${height / 3}"/>
      </geometry>
      <origin xyz="" rpy=""/>
    </collision>
    <xacro:box_inertia m="1.0" x="${length / 3}" y="${width}" z="${height / 3}"
                       o_xyz="${length / 6} 0 ${height / 6}" o_rpy="0 0 0"/>
  </link>
  <xacro:wheel prefix="front_left"/>
  <xacro:wheel prefix="rear_left"/>
  <xacro:wheel prefix="front_right"/>
  <xacro:wheel prefix="rear_right"/>
  
  <!-- Joints -->
  <joint name="base_cutting_unit_joint" type="fixed">
    <parent link="base_link"/>
    <child link="cutting_unit_link"/>
    <origin xyz="${length / 3} 0 0" rpy="0 0 0"/>
  </joint>
  <joint name="base_front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel_link"/>
    <origin xyz="${length / 6} ${(width - wheel_width) / -2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
  <joint name="base_rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_left_wheel_link"/>
    <origin xyz="${length / -6} ${(width - wheel_width) / -2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
  <joint name="base_front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel_link"/>
    <origin xyz="${length / 6} ${(width - wheel_width) / 2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>
  <joint name="base_rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="rear_right_wheel_link"/>
    <origin xyz="${length / -6} ${(width - wheel_width) / 2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

</robot>

